!
!
!
!                                ooooooo  ooooo
!                                 `8888    d8'
!                                   Y888..8P
!                                    `8888'
!                                   .8PY888.
!                                  d8'  `888b
!                                o888o  o88888o
!
!--------------------------------------------------------------------------------
!-------------------------------------- X ---------------------------------------
!--------------------------------------------------------------------------------

Xcursor.theme: Bibata-Original-Ice
Xft.antialias: 1
Xft.hinting: 1
Xft.rgba: rgb
Xft.hintstyle: hintslight
Xft.lcdfilter: lcddefault



!--------------------------------------------------------------------------------
!------------------------------------ XTerm -------------------------------------
!--------------------------------------------------------------------------------
XTerm*highlightSelection     : true
XTerm.ttymodes               : erase ^?
XTerm.vt100.backarrowKey     : false
XTerm.vt100.metaSendsEscape  : true

!-------------------------------- Key Bindings ----------------------------------
xterm*vt100.translations     : #override \n\
	<Btn1Up>                 : select-end(PRIMARY, CLIPBOARD, CUT_BUFFER0) \n\
	Ctrl Shift <Key>C        : copy-selection(CLIPBOARD) \n\
	Ctrl Shift <Key>V        : insert-selection(CLIPBOARD) \n\
	Shift <Key>Home          : scroll-forw(10000000000) \n\
	Shift <Key>End           : scroll-back(10000000000)

!------------------------------------ Fonts -------------------------------------
XTerm.vt100.faceName         : Space Mono:size=12
XTerm*boldMode               : false

!-------------------------------- Color Scheme ----------------------------------
! Zenbones color palette --------------------------------------------------------
xterm*foreground             : rgb:2c/36/3c
xterm*background             : rgb:f0/ed/ec
xterm*cursorColor            : rgb:2c/36/3c

! black
xterm*color0                 : rgb:f0/ed/ec
xterm*color8                 : rgb:cf/c1/ba

! red
xterm*color1                 : rgb:a8/33/4c
xterm*color9                 : rgb:94/25/3e

! green
xterm*color2                 : rgb:4f/6c/31
xterm*color10                : rgb:3f/5a/22

! yellow
xterm*color3                 : rgb:94/49/27
xterm*color11                : rgb:80/3d/1c

! blue
xterm*color4                 : rgb:28/64/86
xterm*color12                : rgb:1d/55/73

! magenta
xterm*color5                 : rgb:88/50/7d
xterm*color13                : rgb:7b/3b/70

! cyan
xterm*color6                 : rgb:3b/89/92
xterm*color14                : rgb:2b/74/7c

! white
xterm*color7                 : rgb:2c/36/3c
xterm*color15                : rgb:4f/5e/68



! -------------------------------------------------------------------------------
!------------------------------------ rxvt --------------------------------------
! -------------------------------------------------------------------------------
URxvt.print-pipe             : "cat > /dev/null"
URxvt.iso14755               : false
URxvt.iso14755_52            : false

!-------------------------------- Key Bindings ----------------------------------
URxvt.keysym.Control-Up      : \033[1;5A
URxvt.keysym.Control-Down    : \033[1;5B
URxvt.keysym.Control-Right   : \033[1;5C
URxvt.keysym.Control-Left    : \033[1;5D
URxvt.keysym.Shift-Control-V : eval:paste_clipboard
URxvt.keysym.Shift-Control-C : eval:selection_to_clipboard
URxvt.keysym.Shift-Up        : command:\033]720;1\007
URxvt.keysym.Shift-Down      : command:\033]721;1\007

!--------------------------------- Extensions -----------------------------------
URxvt.perl-ext-common        : default, matcher, tabbed, resize-font

! matcher makes URLs clickable
URxvt.matcher.button         : 1
URxvt.url-launcher           : /usr/bin/xdg-open

URxvt.tabbed.tab-fg          : 3
URxvt.tabbed.tab-bg          : 0
URxvt.tabbed.tabbar-fg       : 2
URxvt.tabbed.tabbar-bg       : 0

!------------------------------------ Fonts -------------------------------------
URxvt.font                   : xft:Space Mono:size=12
URxvt.scrollBar              : false

!-------------------------------- Color Scheme ----------------------------------
! Zenbones color palette --------------------------------------------------------
*.foreground                 : #2C363C
*.background                 : #F0EDEC
*.cursor                     : #2C363C

! black
*.color0                     : #F0EDEC
*.color8                     : #CFC1BA

! red
*.color1                     : #A8334C
*.color9                     : #94253E

! green
*.color2                     : #4F6C31
*.color10                    : #3F5A22

! yellow
*.color3                     : #944927
*.color11                    : #803D1C

! blue
*.color4                     : #286486
*.color12                    : #1D5573

! magenta
*.color5                     : #88507D
*.color13                    : #7B3B70

! cyan
*.color6                     : #3B8992
*.color14                    : #2B747C

! white
*.color7                     : #2C363C
*.color15                    : #4F5E68



!--------------------------------------------------------------------------------
!----------------------------------- xst/st -------------------------------------
!--------------------------------------------------------------------------------
st.font                      : Space Mono:size=12
st.borderless                : 1
st.opacity                   : 1

